FROM python:3.12-slim

ARG NODE_VERSION=22.17.0
ARG NODE_SHA256=325c0f1261e0c61bcae369a1274028e9cfb7ab7949c05512c5b1e630f7e80e12
ARG HTTPS_PROXY
ENV HTTPS_PROXY=${HTTPS_PROXY} \
    HTTP_PROXY=${HTTPS_PROXY} \
    NODE_ENV=development \
    PATH=/opt/node-v22.17.0-linux-x64/bin:${PATH}

RUN python -c "import hashlib,tarfile,urllib.request; u='https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-x64.tar.xz'; p='/tmp/node.tar.xz'; urllib.request.urlretrieve(u,p); actual=hashlib.sha256(open(p,'rb').read()).hexdigest(); assert actual=='${NODE_SHA256}', (actual,'${NODE_SHA256}'); tarfile.open(p,'r:xz').extractall('/opt')" \
    && corepack enable \
    && corepack prepare pnpm@11.9.0 --activate

WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/core/package.json packages/core/package.json
RUN pnpm install --frozen-lockfile

COPY . .
RUN pnpm --filter mingyu-core build

LABEL org.opencontainers.image.source="https://github.com/Brhiza/mingyu" \
      org.opencontainers.image.revision="8e24d474d25d52d8b33533fe6e4dbc50aae6d9c8" \
      yiai.adapter="streamable-http-only"

ENV PORT=3001 \
    HTTPS_PROXY= \
    HTTP_PROXY=
EXPOSE 3001
CMD ["pnpm", "exec", "tsx", "--tsconfig", "mcp/tsconfig.json", "mcp/src/http-server.ts"]
